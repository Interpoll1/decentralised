# Port the HTTP server listens on.
PORT=3000

# "sqlite" (default, persistent — recommended) or "memory" (dev/tests only;
# all data is lost on every restart).
STORE_DRIVER=sqlite

# Where the SQLite database file lives. The directory is created
# automatically if it doesn't exist. Ignored when STORE_DRIVER=memory.
DB_PATH=./data/moderation.db

# Optional. If set, this raw string becomes the bootstrap admin API key
# (scopes: read, write, admin) instead of a randomly generated one being
# printed to stdout on first run. Set this via a secrets manager in
# production rather than committing it anywhere. Only used the very first
# time the server starts with an empty database — after that, the key
# already in the database is reused.
# BOOTSTRAP_ADMIN_KEY=mod_sk_change_me_to_something_random_and_long
