MYSQL_HOST=127.0.0.1
MYSQL_USER=interpoll
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=interpoll
MYSQL_PORT=3306
# MySQL TLS: verification is ON by default. For a private/self-signed DB CA,
# point MYSQL_SSL_CA at the CA bundle (PEM). For local dev only, set
# MYSQL_SSL_INSECURE=true to skip verification (logs a warning; never use in prod).
# MYSQL_SSL_CA=/path/to/ca.pem
# MYSQL_SSL_INSECURE=false
DOMAIN=https://endless.sbs
FRONTEND_ORIGIN=https://endless.sbs
JWT_SECRET=replace-with-32-byte-random-secret
VOTE_RESERVATION_SECRET=replace-with-32-byte-random-secret
