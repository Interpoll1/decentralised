  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:relay": "node relay-server.js",
    "dev:gun": "node gun-relay-server/gun-relay.js",
    "dev:peer": "node peer.js",
    "build": "vite build",
